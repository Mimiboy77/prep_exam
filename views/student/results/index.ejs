<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>My Results</h2>
  <a href="/student/progress" class="btn btn-primary">View Progress</a>
</div>

<table class="table table-bordered table-hover">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Exam Type</th>
      <th>Subject</th>
      <th>Score</th>
      <th>Status</th>
      <th>Date Taken</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (studentExams.length === 0) { %>
      <tr><td colspan="7" class="text-center">No results yet. Take an exam first!</td></tr>
    <% } else { %>
      <% studentExams.forEach(function(exam, index) { %>
        <%
          var subjectName = 'N/A';
          if (exam.examId && exam.examKey) {
            var matchedSubject = exam.examId.subjects.find(function(s) {
              return s.subjectId && (exam.examId._id.toString() + s.subjectId._id.toString()) === exam.examKey;
            });
            if (matchedSubject) subjectName = matchedSubject.subjectId.name;
          }
        %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= exam.examId ? exam.examId.examType : 'N/A' %></td>
          <td><%= subjectName %></td>
          <td>
            <span class="badge bg-<%= exam.score >= 40 ? 'success' : 'danger' %>">
              <%= exam.score %>%
            </span>
          </td>
          <td>
            <span class="badge bg-success"><%= exam.status %></span>
          </td>
          <td><%= exam.dateTaken ? exam.dateTaken.toDateString() : 'N/A' %></td>
          <td>
            <a href="/student/results/<%= exam._id %>" class="btn btn-sm btn-primary">View</a>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>

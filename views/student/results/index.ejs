<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>My Results</h2>
  <a href="/student/progress" class="btn btn-primary">View Progress</a>
</div>

<table class="table table-bordered table-hover">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Subject</th>
      <th>Score</th>
      <th>Status</th>
      <th>Date Taken</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (studentExams.length === 0) { %>
      <tr><td colspan="6" class="text-center">No results yet. Take an exam first!</td></tr>
    <% } else { %>
      <% studentExams.forEach((exam, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= exam.examId && exam.examId.subjectId ? exam.examId.subjectId.name : 'N/A' %></td>
          <td>
            <span class="badge bg-<%= exam.score >= 50 ? 'success' : 'danger' %>">
              <%= exam.score %>%
            </span>
          </td>
          <td>
            <span class="badge bg-success"><%= exam.status %></span>
          </td>
          <td><%= exam.dateTaken.toDateString() %></td>
          <td>
            <a href="/student/results/<%= exam._id %>" class="btn btn-sm btn-primary">View</a>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
<div class="row justify-content-center">
  <div class="col-lg-10">

    <!-- Score Card -->
    <div class="card shadow mb-4">
      <div class="card-header text-white fw-bold d-flex justify-content-between align-items-center"
        style="background: #2c3e50; font-size: 1.1rem;">
        <span>
          <i class="bi bi-mortarboard-fill me-2"></i>
          JAMB Result — <%= studentExam.examId.examType %>
        </span>
        <span class="text-white-50 small">
          <%= studentExam.dateTaken ? new Date(studentExam.dateTaken).toDateString() : '' %>
        </span>
      </div>

      <div class="card-body p-4">

        <!-- Total Score Banner -->
        <%
          var totalScore  = studentExam.totalScore || 0;
          var passJamb    = totalScore >= 180;
        %>
        <div class="text-center mb-4">
          <div class="display-4 fw-bold <%= passJamb ? 'text-success' : 'text-danger' %>">
            <%= totalScore %> / 400
          </div>
          <div class="mt-2">
            <% if (passJamb) { %>
              <span class="badge bg-success fs-6 px-4 py-2">PASS</span>
            <% } else { %>
              <span class="badge bg-danger fs-6 px-4 py-2">FAIL</span>
            <% } %>
          </div>
          <div class="text-muted mt-2 small">Pass mark: 180 / 400</div>
        </div>

        <!-- Per Subject Score Breakdown -->
        <h6 class="fw-bold mb-3">Score Breakdown by Subject:</h6>
        <div class="row g-3 mb-4">
          <% subjectResults.forEach(function(sr) { %>
            <%
              var pct     = sr.score;
              var barColor = pct >= 50 ? 'bg-success' : pct >= 40 ? 'bg-warning' : 'bg-danger';
            %>
            <div class="col-md-6">
              <div class="card border h-100">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong><%= sr.subjectId.name %></strong>
                    <span class="badge <%= pct >= 50 ? 'bg-success' : pct >= 40 ? 'bg-warning text-dark' : 'bg-danger' %> fs-6">
                      <%= sr.score %> / 100
                    </span>
                  </div>
                  <div class="progress mb-2" style="height: 10px;">
                    <div class="progress-bar <%= barColor %>"
                      style="width: <%= sr.score %>%"></div>
                  </div>
                  <div class="d-flex justify-content-between small text-muted">
                    <span>Correct: <%= sr.correct %> / <%= sr.totalQuestions %></span>
                    <span><%= sr.score %>%</span>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Total Score Progress Bar -->
        <%
          var totalPct = Math.round((totalScore / 400) * 100);
        %>
        <div class="card bg-light mb-4">
          <div class="card-body">
            <div class="d-flex justify-content-between mb-1">
              <strong>Overall Score</strong>
              <strong><%= totalScore %> / 400</strong>
            </div>
            <div class="progress" style="height: 14px;">
              <div class="progress-bar <%= passJamb ? 'bg-success' : 'bg-danger' %> fw-bold"
                style="width: <%= totalPct %>%">
                <%= totalPct %>%
              </div>
            </div>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="d-flex gap-2 flex-wrap">
          <a href="/student/results" class="btn btn-outline-secondary">
            &larr; All Results
          </a>
          <a href="/student/exams" class="btn btn-outline-primary">
            Back to Exams
          </a>
          <a href="/student/progress" class="btn btn-outline-success">
            View Progress
          </a>
        </div>

      </div>
    </div>

    <!-- Per Subject Question Review -->
    <% subjectResults.forEach(function(sr, srIndex) { %>
      <div class="card shadow mb-4">
        <div class="card-header fw-bold d-flex justify-content-between align-items-center"
          style="background: #f8f9fa;">
          <span>
            <i class="bi bi-book me-2"></i>
            <%= sr.subjectId.name %> — Question Review
          </span>
          <span class="badge bg-primary">
            <%= sr.correct %> / <%= sr.totalQuestions %> correct
          </span>
        </div>

        <div class="card-body p-0">
          <% if (sr.questions.length === 0) { %>
            <div class="p-3 text-muted">No questions found for this subject.</div>
          <% } else { %>

            <div class="accordion" id="accordion-<%= srIndex %>">
              <% sr.questions.forEach(function(question, qIndex) { %>
                <%
                  // Find student's answer for this question
                  var studentAnswer = '';
                  sr.answers.forEach(function(ans) {
                    if (ans.questionId && ans.questionId.toString() === question._id.toString()) {
                      studentAnswer = ans.selectedOption;
                    }
                  });
                  var isCorrect   = studentAnswer === question.answer;
                  var isAttempted = studentAnswer !== '';
                %>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button
                      class="accordion-button collapsed py-2"
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target="#q-<%= srIndex %>-<%= qIndex %>"
                      style="font-size: 0.9rem;">
                      <span class="me-3">
                        <% if (!isAttempted) { %>
                          <span class="badge bg-secondary">Skipped</span>
                        <% } else if (isCorrect) { %>
                          <span class="badge bg-success">
                            <i class="bi bi-check-lg"></i> Correct
                          </span>
                        <% } else { %>
                          <span class="badge bg-danger">
                            <i class="bi bi-x-lg"></i> Wrong
                          </span>
                        <% } %>
                      </span>
                      <span>Q<%= qIndex + 1 %>. <%= question.questionText.substring(0, 80) %><%= question.questionText.length > 80 ? '...' : '' %></span>
                    </button>
                  </h2>

                  <div id="q-<%= srIndex %>-<%= qIndex %>"
                    class="accordion-collapse collapse">
                    <div class="accordion-body py-3">

                      <!-- Full Question Text -->
                      <p class="fw-semibold mb-3"><%= question.questionText %></p>

                      <!-- Options -->
                      <%
                        var letters = ['A', 'B', 'C', 'D'];
                      %>
                      <% question.options.forEach(function(option, oIndex) { %>
                        <%
                          var isCorrectOpt  = option === question.answer;
                          var isStudentOpt  = option === studentAnswer;
                          var optClass      = '';
                          var icon          = '';
                          if (isCorrectOpt) {
                            optClass = 'border-success bg-success bg-opacity-10';
                            icon     = '<i class="bi bi-check-circle-fill text-success ms-auto"></i>';
                          } else if (isStudentOpt && !isCorrectOpt) {
                            optClass = 'border-danger bg-danger bg-opacity-10';
                            icon     = '<i class="bi bi-x-circle-fill text-danger ms-auto"></i>';
                          }
                        %>
                        <div class="d-flex align-items-start gap-2 p-2 rounded mb-2 border <%= optClass %>">
                          <span class="fw-bold text-muted" style="min-width:20px;">
                            <%= letters[oIndex] %>.
                          </span>
                          <span class="flex-grow-1"><%= option %></span>
                          <%- icon %>
                        </div>
                      <% }) %>

                      <!-- Result Summary -->
                      <div class="mt-3 small">
                        <% if (!isAttempted) { %>
                          <span class="text-muted">
                            <i class="bi bi-dash-circle me-1"></i>
                            You did not answer this question.
                          </span>
                          <span class="ms-3 text-success fw-bold">
                            Correct answer: <%= question.answer %>
                          </span>
                        <% } else if (isCorrect) { %>
                          <span class="text-success fw-bold">
                            <i class="bi bi-check-circle me-1"></i>
                            Your answer was correct.
                          </span>
                        <% } else { %>
                          <span class="text-danger fw-bold">
                            <i class="bi bi-x-circle me-1"></i>
                            Your answer: <%= studentAnswer %>
                          </span>
                          <span class="ms-3 text-success fw-bold">
                            Correct answer: <%= question.answer %>
                          </span>
                        <% } %>
                      </div>

                      <!-- Explanation -->
                      <% if (question.explanation) { %>
                        <div class="alert alert-info mt-3 mb-0 py-2 small">
                          <i class="bi bi-lightbulb me-1"></i>
                          <strong>Explanation:</strong> <%= question.explanation %>
                        </div>
                      <% } %>

                    </div>
                  </div>
                </div>

              <% }) %>
            </div>

          <% } %>
        </div>
      </div>
    <% }) %>

  </div>
</div>
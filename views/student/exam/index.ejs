<h2 class="mb-4">Available Exams</h2>

<table class="table table-bordered table-hover">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Subject</th>
      <th>Questions</th>
      <th>Timer (mins)</th>
      <th>Retake Policy</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (exams.length === 0) { %>
      <tr><td colspan="6" class="text-center">No exams available yet.</td></tr>
    <% } else { %>
      <% exams.forEach((exam, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= exam.subjectId.name %></td>
          <td><%= exam.questionCount %></td>
          <td><%= exam.timer %></td>
          <td><%= exam.retakePolicy %></td>
          <td>
            <a href="/student/exams/instruction/<%= exam._id %>" class="btn btn-sm btn-primary">
              Start
            </a>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
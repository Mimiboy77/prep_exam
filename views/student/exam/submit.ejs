<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-body p-4 text-center">
        <h3 class="mb-4">Confirm Submission</h3>
        <p class="mb-4">Are you sure you want to submit your exam? You cannot change your answers after submission.</p>

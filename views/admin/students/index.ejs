<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Students</h2>
</div>

<!-- Filter by School -->
<form action="/admin/students" method="GET" class="mb-4">
  <div class="row">
    <div class="col-md-4">
      <select name="schoolId" class="form-select" onchange="this.form.submit()">
        <option value="">-- All Schools --</option>
        <% schools.forEach(school => { %>
          <option value="<%= school._id %>"
            <%= selectedSchool === school._id.toString() ? 'selected' : '' %>>
            <%= school.name %>
          </option>
        <% }) %>
      </select>
    </div>
  </div>
</form>

<table class="table table-bordered table-hover">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Name</th>
      <th>Username</th>
      <th>Class</th>
      <th>Department</th>
      <th>School</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (students.length === 0) { %>
      <tr><td colspan="7" class="text-center">No students found.</td></tr>
    <% } else { %>
      <% students.forEach((student, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= student.surname %> <%= student.firstname %></td>
          <td><%= student.username %></td>
          <td><%= student.class %></td>
          <td><%= student.department %></td>
          <td><%= student.schoolId ? student.schoolId.name : 'N/A' %></td>
          <td>
            <a href="/admin/students/<%= student._id %>" class="btn btn-sm btn-primary">View</a>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
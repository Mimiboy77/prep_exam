<div class="mb-4">
  <a href="/admin/students" class="btn btn-secondary btn-sm mb-3">Back to Students</a>
  <h2><%= student.surname %> <%= student.firstname %></h2>
  <p><strong>Username:</strong> <%= student.username %></p>
  <p><strong>Class:</strong> <%= student.class %></p>
  <p><strong>Department:</strong> <%= student.department %></p>
  <p><strong>School:</strong> <%= student.schoolId ? student.schoolId.name : 'N/A' %></p>
</div>

<h4 class="mb-3">Exam History</h4>
<table class="table table-bordered table-hover">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Subject</th>
      <th>Score</th>
      <th>Status</th>
      <th>Date Taken</th>
    </tr>
  </thead>
  <tbody>
    <% if (studentExams.length === 0) { %>
      <tr><td colspan="5" class="text-center">No exams taken yet.</td></tr>
    <% } else { %>
      <% studentExams.forEach((exam, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= exam.examId && exam.examId.subjectId ? exam.examId.subjectId.name : 'N/A' %></td>
          <td><%= exam.score %>%</td>
          <td><span class="badge bg-<%= exam.status === 'completed' ? 'success' : 'warning' %>"><%= exam.status %></span></td>
          <td><%= exam.dateTaken.toDateString() %></td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
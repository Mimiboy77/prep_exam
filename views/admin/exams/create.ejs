<div class="card shadow">
  <div class="card-header bg-dark text-white">
    <h4 class="mb-0">Create Exam</h4>
  </div>
  <div class="card-body p-4">

    <form action="/admin/exams/create" method="POST" id="examForm">

      <!-- Exam Type -->
      <div class="row mb-4">
        <div class="col-md-4">
          <label class="form-label fw-bold">Exam Type</label>
          <select name="examType" class="form-select" id="examTypeSelect"
            onchange="toggleCustomName(this.value)" required>
            <option value="">-- Select Exam Type --</option>
            <option value="WAEC">WAEC</option>
            <option value="NECO">NECO</option>
            <option value="JAMB">JAMB</option>
            <option value="custom">Custom (type your own)</option>
          </select>
        </div>

        <div class="col-md-4 d-none" id="customNameDiv">
          <label class="form-label fw-bold">Custom Exam Name</label>
          <input type="text" name="customExamName" class="form-control"
            placeholder="e.g. Mock Exam 2025" />
        </div>

        <div class="col-md-4">
          <label class="form-label fw-bold">Visibility</label>
          <div class="form-check mt-2">
            <input type="checkbox" name="isVisible" class="form-check-input"
              id="isVisible" checked />
            <label class="form-check-label" for="isVisible">
              Visible to students immediately
            </label>
          </div>
        </div>
      </div>

      <hr/>

      <!-- Subjects Section -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Subjects</h5>
        <button type="button" class="btn btn-success btn-sm"
          onclick="addSubjectRow()">
          + Add Subject
        </button>
      </div>

      <div id="subjectsContainer">
        <!-- Subject rows added dynamically -->
      </div>

      <hr/>

      <button type="submit" class="btn btn-primary px-5">Create Exam</button>
      <a href="/admin/exams" class="btn btn-secondary ms-2">Cancel</a>

    </form>
  </div>
</div>

<!-- Subject Row Template -->
<template id="subjectRowTemplate">
  <div class="subject-row card border mb-3">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 text-muted">Subject</h6>
        <button type="button" class="btn btn-sm btn-outline-danger"
          onclick="removeSubjectRow(this)">Remove</button>
      </div>

      <div class="row g-3">

        <div class="col-md-4">
          <label class="form-label">Subject</label>
          <select name="subjectIds" class="form-select subject-select" required
            onchange="loadSyllabus(this)">
            <option value="">-- Select Subject --</option>
            <% subjects.forEach(function(subject) { %>
              <option value="<%= subject._id %>"><%= subject.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-4">
          <label class="form-label">Syllabus Topic <span class="text-muted">(optional)</span></label>
          <select name="syllabusIds" class="form-select syllabus-select">
            <option value="">-- All Topics --</option>
          </select>
        </div>

        <div class="col-md-2">
          <label class="form-label">No. of Questions</label>
          <input type="number" name="questionCounts" class="form-control" min="1" required />
        </div>

        <div class="col-md-2">
          <label class="form-label">Timer (mins)</label>
          <input type="number" name="timers" class="form-control" min="1" required />
        </div>

        <div class="col-md-3">
          <label class="form-label">Retake Policy</label>
          <select name="retakePolicies" class="form-select">
            <option value="once">Once</option>
            <option value="unlimited">Unlimited</option>
            <option value="none">None</option>
          </select>
        </div>

        <div class="col-md-3 d-flex align-items-end gap-3">
          <div class="form-check">
            <input type="checkbox" name="randomizes" class="form-check-input"
              id="randomize" checked />
            <label class="form-check-label">Randomize</label>
          </div>
          <div class="form-check">
            <input type="checkbox" name="isLocked" class="form-check-input" />
            <label class="form-check-label">Lock Subject</label>
          </div>
        </div>

      </div>
    </div>
  </div>
</template>

<script>
  // Syllabus data from server
  const allSyllabus = <%- JSON.stringify(syllabus) %>;

  // Show or hide custom name input
  function toggleCustomName(value) {
    var div = document.getElementById('customNameDiv');
    if (value === 'custom') {
      div.classList.remove('d-none');
    } else {
      div.classList.add('d-none');
    }
  }

  // Add a new subject row
  function addSubjectRow() {
    var template  = document.getElementById('subjectRowTemplate');
    var clone     = template.content.cloneNode(true);
    document.getElementById('subjectsContainer').appendChild(clone);
  }

  // Remove a subject row
  function removeSubjectRow(btn) {
    btn.closest('.subject-row').remove();
  }

  // Load syllabus topics when subject changes
  function loadSyllabus(select) {
    var subjectId     = select.value;
    var row           = select.closest('.subject-row');
    var syllabusSelect = row.querySelector('.syllabus-select');

    // Clear current options
    syllabusSelect.innerHTML = '<option value="">-- All Topics --</option>';

    // Filter syllabus for selected subject
    allSyllabus.forEach(function(item) {
      if (item.subjectId && item.subjectId._id === subjectId) {
        var option       = document.createElement('option');
        option.value     = item._id;
        option.textContent = item.topic;
        syllabusSelect.appendChild(option);
      }
    });
  }

  // Add first subject row on page load
  addSubjectRow();
</script>
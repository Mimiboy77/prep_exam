<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header bg-dark text-white">
        <h4 class="mb-0">Exam Settings — <%= exam.examType %></h4>
      </div>
      <div class="card-body p-4">

        <form action="/admin/exams/settings/<%= exam._id %>" method="POST">

          <div class="mb-4">
            <label class="form-label fw-bold">Visibility</label>
            <div class="form-check">
              <input type="checkbox" name="isVisible" class="form-check-input"
                id="isVisible" <%= exam.isVisible ? 'checked' : '' %> />
              <label class="form-check-label" for="isVisible">
                Visible to students
              </label>
            </div>
          </div>

          <!-- Subjects summary -->
          <h6 class="fw-bold mb-3">Subjects in this exam:</h6>
          <table class="table table-bordered mb-4">
            <thead class="table-dark">
              <tr>
                <th>Subject</th>
                <th>Questions</th>
                <th>Timer</th>
                <th>Locked</th>
              </tr>
            </thead>
            <tbody>
              <% exam.subjects.forEach(function(subject) { %>
                <tr>
                  <td><%= subject.subjectId ? subject.subjectId.name : 'N/A' %></td>
                  <td><%= subject.questionCount %></td>
                  <td><%= subject.timer %> mins</td>
                  <td>
                    <span class="badge <%= subject.isLocked ? 'bg-danger' : 'bg-success' %>">
                      <%= subject.isLocked ? 'Locked' : 'Open' %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <button type="submit" class="btn btn-warning w-100">Update Settings</button>
          <a href="/admin/exams" class="btn btn-secondary w-100 mt-2">Cancel</a>

        </form>
      </div>
    </div>
  </div>
</div>
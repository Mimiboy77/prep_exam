<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Teachers</h2>
  <a href="/admin/teachers/add" class="btn btn-primary">Add Teacher</a>
</div>

<table class="table table-bordered table-hover">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Name</th>
      <th>Username</th>
      <th>Assigned Subjects</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (teachers.length === 0) { %>
      <tr><td colspan="5" class="text-center">No teachers found.</td></tr>
    <% } else { %>
      <% teachers.forEach(function(teacher, index) { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= teacher.surname %> <%= teacher.firstname %></td>
          <td><%= teacher.username %></td>
          <td>
            <% if (teacher.assignedSubjects.length === 0) { %>
              <span class="text-muted">None</span>
            <% } else { %>
              <% teacher.assignedSubjects.forEach(function(subject) { %>
                <span class="badge bg-primary me-1"><%= subject.name %></span>
              <% }) %>
            <% } %>
          </td>
          <td>
            <a href="/admin/teachers/assign/<%= teacher._id %>" class="btn btn-sm btn-warning">Assign Subject</a>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>

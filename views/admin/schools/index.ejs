<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Schools</h2>
    <a href="/admin/schools/add" class="btn btn-primary">Add School</a>
  </div>

  <table class="table table-bordered table-hover">
    <thead class="table-dark">
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Location</th>
        <th>Date Added</th>
      </tr>
    </thead>
    <tbody>
      <% if (schools.length === 0) { %>
        <tr><td colspan="4" class="text-center">No schools found.</td></tr>
      <% } else { %>
        <% schools.forEach((school, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= school.name %></td>
            <td><%= school.location %></td>
            <td><%= school.createdAt.toDateString() %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>

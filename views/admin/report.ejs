<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Performance Report</h2>
</div>

<div class="card shadow mb-4">
  <div class="card-header bg-dark text-white">
    <h5 class="mb-0">Filter Report</h5>
  </div>
  <div class="card-body p-4">

    <form action="/admin/report/download" method="GET">

      <div class="row g-3">

        <div class="col-md-3">
          <label class="form-label fw-bold">School</label>
          <select name="schoolId" class="form-select">
            <option value="">-- All Schools --</option>
            <% schools.forEach(function(school) { %>
              <option value="<%= school._id %>"><%= school.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-bold">Subject</label>
          <select name="subjectId" class="form-select">
            <option value="">-- All Subjects --</option>
            <% subjects.forEach(function(subject) { %>
              <option value="<%= subject._id %>"><%= subject.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-2">
          <label class="form-label fw-bold">Class</label>
          <input type="text" name="studentClass" class="form-control"
            placeholder="e.g SS2" />
        </div>

        <div class="col-md-2">
          <label class="form-label fw-bold">Date From</label>
          <input type="date" name="dateFrom" class="form-control" />
        </div>

        <div class="col-md-2">
          <label class="form-label fw-bold">Date To</label>
          <input type="date" name="dateTo" class="form-control" />
        </div>

      </div>

      <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-success px-4">
          ⬇️ Download Excel Report
        </button>
        <a href="/admin/dashboard" class="btn btn-secondary">Cancel</a>
      </div>

    </form>
  </div>
</div>

<!-- Info Card -->
<div class="card border-info">
  <div class="card-body">
    <h6 class="text-info fw-bold">📊 What this report includes:</h6>
    <p class="mb-1">Each row represents one exam attempt by a student.</p>
    <ul class="mb-0">
      <li>Full Name, Class, Department, School</li>
      <li>Subject, Score %, Pass or Fail (40% and above = Pass)</li>
      <li>Date Taken</li>
      <li>Average score summary at the bottom</li>
    </ul>
  </div>
</div>
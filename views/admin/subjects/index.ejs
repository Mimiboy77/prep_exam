<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Subjects</h2>
  <a href="/admin/subjects/add" class="btn btn-primary">Add Subject</a>
</div>

<table class="table table-bordered table-hover">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Name</th>
      <th>Description</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (subjects.length === 0) { %>
      <tr><td colspan="4" class="text-center">No subjects found.</td></tr>
    <% } else { %>
      <% subjects.forEach(function(subject, index) { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= subject.name %></td>
          <td><%= subject.description || 'N/A' %></td>
          <td>
            <a href="/admin/subjects/edit/<%= subject._id %>" class="btn btn-sm btn-warning">Edit</a>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title : 'Exam Prep App' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Exam Prep App</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <% if (user && user.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/teachers">Teachers</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/subjects">Subjects</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/exams">Exams</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/students">Students</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/schools">Schools</a></li>
          <% } else if (user && user.role === 'teacher') { %>
            <li class="nav-item"><a class="nav-link" href="/teacher/dashboard">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/teacher/questions">Questions</a></li>
          <% } else if (user && user.role === 'student') { %>
            <li class="nav-item"><a class="nav-link" href="/student/dashboard">Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/student/exams">Exams</a></li>
            <li class="nav-item"><a class="nav-link" href="/student/results">Results</a></li>
            <li class="nav-item"><a class="nav-link" href="/student/progress">Progress</a></li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/register">Register</a></li>
          <% } %>
          <% if (user) { %>
            <li class="nav-item"><a class="nav-link text-danger" href="/auth/logout">Logout</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Flash Messages -->
  <div class="container mt-3">
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success"><%= success_msg %></div>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger"><%= error_msg %></div>
    <% } %>
  </div>

  <!-- Page Content -->
  <div class="container mt-4">
    <%- body %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<h2 class="mb-4">Teacher Dashboard</h2>

<div class="row g-4 mb-4">

  <div class="col-md-4">
    <div class="card text-white bg-primary shadow">
      <div class="card-body">
        <h5 class="card-title">My Questions</h5>
        <p class="display-6"><%= questionCount %></p>
        <a href="/teacher/questions" class="btn btn-light btn-sm">View All</a>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card text-white bg-success shadow">
      <div class="card-body">
        <h5 class="card-title">Assigned Subjects</h5>
        <p class="display-6"><%= teacher.assignedSubjects.length %></p>
      </div>
    </div>
  </div>

</div>

<h4 class="mb-3">My Assigned Subjects</h4>
<table class="table table-bordered">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Subject</th>
    </tr>
  </thead>
  <tbody>
    <% if (teacher.assignedSubjects.length === 0) { %>
      <tr><td colspan="2" class="text-center">No subjects assigned yet.</td></tr>
    <% } else { %>
      <% teacher.assignedSubjects.forEach((subject, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= subject.name %></td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>

<a href="/teacher/questions/add" class="btn btn-primary mt-3">Add New Question</a>
<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow">
      <div class="card-body p-4">
        <h3 class="mb-4">Edit Question</h3>

        <form action="/teacher/questions/edit/<%= question._id %>" method="POST" enctype="multipart/form-data">

          <div class="mb-3">
            <label class="form-label">Subject</label>
            <select name="subjectId" class="form-select" required>
              <option value="">-- Select Subject --</option>
              <% subjects.forEach(function(subject) { %>
                <option value="<%= subject._id %>"
                  <%= question.subjectId._id.toString() === subject._id.toString() ? 'selected' : '' %>>
                  <%= subject.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Syllabus Topic</label>
            <select name="syllabusId" class="form-select" required>
              <option value="">-- Select Topic --</option>
              <% syllabus.forEach(function(item) { %>
                <option value="<%= item._id %>"
                  <%= question.syllabusId._id.toString() === item._id.toString() ? 'selected' : '' %>>
                  <%= item.topic %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Question Text</label>
            <textarea name="questionText" class="form-control" rows="3" required><%= question.questionText %></textarea>
          </div>

          <!-- Image Upload -->
          <div class="mb-3">
            <label class="form-label">Question Image <span class="text-muted">(optional)</span></label>
            <% if (question.image) { %>
              <div class="mb-2">
                <img src="<%= question.image %>" class="img-thumbnail" style="max-width:300px;" />
                <p class="small text-muted mt-1">Upload a new image to replace this one.</p>
              </div>
            <% } %>
            <input type="file" name="image" class="form-control" accept="image/*"
              onchange="previewImage(this)" />
            <div class="mt-2" id="imagePreview"></div>
          </div>

          <% question.options.forEach(function(option, index) { %>
            <div class="mb-3">
              <label class="form-label">Option <%= ['A','B','C','D'][index] %></label>
              <input type="text" name="options" class="form-control" value="<%= option %>" required />
            </div>
          <% }) %>

          <!-- Answer by option letter -->
          <div class="mb-3">
            <label class="form-label">Correct Answer</label>
            <select name="answerIndex" class="form-select" required>
              <option value="">-- Select Correct Option --</option>
              <% ['A','B','C','D'].forEach(function(letter, index) { %>
                <option value="<%= index %>"
                  <%= question.answer === question.options[index] ? 'selected' : '' %>>
                  Option <%= letter %> is correct
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Explanation <span class="text-muted">(optional)</span></label>
            <textarea name="explanation" class="form-control" rows="2"><%= question.explanation %></textarea>
          </div>

          <button type="submit" class="btn btn-warning w-100">Update Question</button>
          <a href="/teacher/questions" class="btn btn-secondary w-100 mt-2">Cancel</a>

        </form>
      </div>
    </div>
  </div>
</div>

<script>
  function previewImage(input) {
    const preview = document.getElementById('imagePreview');
    preview.innerHTML = '';
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        preview.innerHTML =
          '<img src="' + e.target.result + '" class="img-thumbnail mt-2" style="max-width:300px;" />';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>